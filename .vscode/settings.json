{
    "python.analysis.typeCheckingMode": "strict",
    "python.analysis.diagnosticSeverityOverrides": {
        "reportPrivateUsage": "none"
    },
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/.venv": true,
        "**/ctre_sim": true
    },
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000
}
